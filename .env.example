# ==============================================================================
# TestFlight MCP server configuration — copy to .env and adjust.
# Every variable is validated at startup (src/config/index.ts); invalid
# configuration fails fast with a readable report.
# ==============================================================================

NODE_ENV=development

# --- App Store Connect credentials (required for live feedback) ---------------
# Create an API key: App Store Connect → Users and Access → Integrations →
# App Store Connect API → Team Keys → "+". Role: Developer (or App Manager).
# Download the .p8 ONCE and keep it out of the repo (gitignored: *.p8).
ASC_ISSUER_ID=
ASC_KEY_ID=
# Exactly one key source:
ASC_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
# ASC_PRIVATE_KEY_BASE64=            # base64 of the .p8 file (Lambda-friendly)
# Default app for the feedback tools (find it with the list_apps tool):
# ASC_APP_ID=1234567890
# ASC_API_BASE_URL=https://api.appstoreconnect.apple.com

# --- Local state ---------------------------------------------------------------
# SQLite database for processed flags, cached feedback, analyses, TODOs,
# duplicate groups and linked issues. ':memory:' works; on Lambda use /tmp.
STATE_DB_PATH=./data/testflight.db
SCREENSHOTS_DIR=./screenshots

# --- AI analysis (optional) ------------------------------------------------------
# Without a key, analyze_feedback hands screenshots + context to the MCP host
# model (Claude Code itself does the vision analysis — zero config needed).
# With a key, the server analyzes autonomously via the Claude API.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Issue trackers (optional; configure any subset, all-or-nothing each) --------
# GITHUB_TOKEN=ghp_xxx                # needs issues:write on the repo
# GITHUB_REPO=owner/repo
# JIRA_BASE_URL=https://yourteam.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=
# JIRA_PROJECT_KEY=PROJ
# JIRA_ISSUE_TYPE=Bug
# LINEAR_API_KEY=lin_api_xxx
# LINEAR_TEAM_ID=

# --- Identity (reported in the MCP initialize handshake) ---------------------
SERVER_NAME=mcp-server-appstoreconnect
SERVER_VERSION=0.1.0
# MCP_INSTRUCTIONS=Optional usage hints surfaced to connecting clients.

# --- Transport ----------------------------------------------------------------
# http | stdio  (the --stdio CLI flag overrides this)
MCP_TRANSPORT=http
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
HTTP_BODY_LIMIT_BYTES=1048576
# Comma-separated browser origins allowed to reach the server (CORS +
# DNS-rebinding protection). Empty = only localhost origins are accepted.
ALLOWED_ORIGINS=

# --- Logging --------------------------------------------------------------------
LOG_LEVEL=info
LOG_PRETTY=true

# --- Authentication (HTTP transport) ----------------------------------------------
# none | api-key | jwt
AUTH_MODE=none
# api-key mode: comma-separated `key:scopeA|scopeB` entries; omit scopes for `*`.
# API_KEYS=local-dev-key:*
# jwt mode: provide a shared secret OR a JWKS endpoint.
# JWT_SECRET=
# JWT_JWKS_URL=https://auth.example.com/.well-known/jwks.json
# JWT_ISSUER=https://auth.example.com/
# JWT_AUDIENCE=mcp-server

# --- Rate limiting (HTTP transport) ----------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# --- Sessions & requests -----------------------------------------------------------
SESSION_TTL_MS=1800000
# true on Lambda/serverless: ephemeral pre-initialized sessions, no server-push.
STATELESS=false
REQUEST_TIMEOUT_MS=30000
SHUTDOWN_TIMEOUT_MS=10000

# --- Observability --------------------------------------------------------------------
METRICS_ENABLED=true
